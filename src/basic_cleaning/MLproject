name: basic_cleaning
conda_env: conda.yml

entry_points:
  main:
    parameters:

      input_artifact:
        description: Fully qualified name of the raw input artifact in W&B (e.g. sample.csv:latest)
        type: string

      output_artifact:
        description: Name for the cleaned output artifact to create in W&B (e.g. clean_sample.csv)
        type: string

      output_type:
        description: Type of the output artifact, used to categorize it in W&B (e.g. clean_sample)
        type: string

      output_description:
        description: A brief description of the cleaned output artifact
        type: string

      min_price:
        description: Minimum accepted nightly price; rows below this value are dropped
        type: float

      max_price:
        description: Maximum accepted nightly price; rows above this value are dropped
        type: float

    command: >-
        python run.py  --input_artifact {input_artifact}  --output_artifact {output_artifact}  --output_type {output_type}  --output_description {output_description}  --min_price {min_price}  --max_price {max_price}
